{
  "expo": {
    "name": "CardboardCaddie",
    "slug": "cardboardcaddie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "cardboardcaddie",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#d4821f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cardboardcaddie.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#d4821f"
      },
      "package": "com.cardboardcaddie.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "hightower27",
    "extra": {
      "eas": {
        "projectId": "cardboardcaddie"
      }
    }
  }
}
